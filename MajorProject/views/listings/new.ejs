<%layout("/layouts/boilerplate.ejs")%>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3><b>Create a new listing</b></h3>

    <form method="post" action="/listings">
      <div class="mb-3">
        <label for="title" class="form-label">Enter title</label>
        <input
          name="listing[title]"
          class="form-control"
          placeholder="Enter title"
          type="text"
        />
      </div>

      <div class="mb-3">
        <label for="desription" class="form-label">Enter description</label>
        <textarea
          name="listing[description]"
          placeholder="Enter description"
          type="text"
          class="form-control"
        ></textarea>
      </div>

      <div class="mb-3">
        <label for="url" class="form-label">Enter Url</label>
        <input
          name="listing[image]"
          class="form-control"
          placeholder="Enter Url"
          type="text"
        />
      </div>
      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="price" class="form-label">Enter price</label>
          <input
            name="listing[price]"
            placeholder="1200"
            type="number"
            class="form-control"
          />
        </div>

        <div class="mb-3 col-md-8">
          <label for="country" class="form-label">Enter Country</label>
          <input
            type="text"
            name="listing[country]"
            placeholder="Enter country"
            class="form-control"
          />
        </div>
      </div>
      <div class="mb-3">
        <label for="location" class="form-label">Enter location</label>
        <input
          name="listing[location]"
          placeholder="udupi, Karnataka"
          type="text"
          class="form-control"
        />
      </div>
      <br />
      <br />
      <button class="btn btn-dark add-btn">add</button>
      <br /><br />
    </form>
  </div>
</div>
