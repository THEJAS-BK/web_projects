<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Listings</title>
  </head>
  <body>
    <h3><b>Create a new listing</b></h3>
    <form method="post" action="/listings">
      <input name="listing[title]" placeholder="Enter title" type="text" />
      <br /><br />
      <textarea
        name="listing[description]"
        placeholder="Enter description"
        type="text"
      ></textarea>
      <br /><br />
      <input name="listing[image]" placeholder="Enter Url" type="text" />
      <br /><br />
      <input name="listing[price]" placeholder="Enter price" type="number" />
      <br /><br />
      <input type="text" name="listing[country]" placeholder="Enter country" />
      <br /><br />
      <input
        name="listing[location]"
        placeholder="Enter location"
        type="text"
      />
      <br /><br />

      <button>add</button>
    </form>
  </body>
</html>
