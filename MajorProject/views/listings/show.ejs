<%layout("/layouts/boilerplate.ejs")%>

<div class="row offset-2 mt-4">
  <div class="col-8">
     <h2><b><%=listing.title%></b></h2>
</div>
<div class="card mb-3 col-8 show-card">
  <img src="<%=listing.image%>" class="card-img-top show-image" alt="Missing image" />
  <br>
  <div class="card-body">
    <p class="class-text"> Owned by: <i><%=listing.owner.username%></i></p>
<p class="class-text">  <%=listing.description%></p>
  <p class="class-text">&#8377;<%=listing.price.toLocaleString("en-IN")%></p>
 <p class="class-text"> <%=listing.location%></p>
    <p class="class-text"><%=listing.country%></p>
</p>
</div>
</div>
<% if(currentUser && currentUser._id.equals(listing.owner._id)) {%>
  <div class="btns mb-4" style="padding-left:0">
  <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark col-1 edit-btn">Edit</a>
<form method="post" action="/listings/<%=listing._id%>?_method=delete">
  <button class="btn btn-dark offset-4">Delete</button>
</form>
</div>
<% } %>

<% if(currentUser){ %>
  <hr>
<div class="col-8">
  <h4>Leave a review</h4>
  <form method="post" action="/listings/<%=listing._id%>/reviews" novalidate class="needs-validation">
    <label for="rating" class="form-label">Rating</label>
    <br>
    <input type="range" min="1" max="5" class="form-range" name="review[rating]" id="rating">
    <div >
      <label for="comment" class="form-label">Comment</label>
      <textarea name="review[comment]" required class="form-control" id="comment" col
      s="8" rows="7"></textarea>
      <div class="valid-feedback">
        This is valid
      </div>
      <div class="invalid-feedback">
        Please Fill the fields
      </div>
    </div>
    <br><br>

<button class="btn btn-dark">Submit</button>
  </form>

  <% } %>
  <hr>
  <h3>All Reviews</h3>
  <br>
<div class="row">
    <%for(review of listing.reviews){%>
      <div class="card col-5 ms-3 mb-3">
        <div class="card-body">
          <div class="card-title">@<%=review.author.username%></div>
          <p class="card-text"><%=review.comment%></p>
          <p class="card-text"><%=review.rating%></p>
           <form class="mb-3" method="post" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=delete">
            <button class="btn btn-dark">delete</button>
           </form>
        </div>
        <br>

      </div>
    <%}%>
</div>
</div>

</div>