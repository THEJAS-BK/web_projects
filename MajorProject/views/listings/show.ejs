<%layout("/layouts/boilerplate.ejs")%>

<div class="row offset-2 mt-4">
  <div class="col-8">
<h3 >Listing Details</h3>
</div>
<div class="card mb-3 col-8 show-card">
  <img src="<%=listing.image%>" class="card-img-top show-image" alt="Missing image" />
  <div class="card-body">

    <div class="class-text"> 
      <b><%=listing.title%></b>
<br>
  <%=listing.description%>
  <br>
  &#8377;<%=listing.price.toLocaleString("en-IN")%>
  <br>
  <%=listing.location%>
  <br>
  <%=listing.country%>

</p>
</div></div>


</div>
  <div class="btns mb-4" style="padding-left:0">
  <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark col-1 edit-btn">Edit</a>
<form method="post" action="/listings/<%=listing._id%>?_method=delete">
  <button class="btn btn-dark offset-4">Delete</button>
</form>
</div>

</div>