<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>edit route</title>
  </head>
  <body>
    <h3>Edit your Chat : <%=chat._id%></h3>
    <p>This chat was send from : <b><%=chat.from%></b></p>
    <p>This chat was sent to : <b><%=chat.to%></b></p>

    <form method="post" action="/chats/<%=chat._id%>?_method=put">
      <textarea name="editText" rows="10" cols="25"><%=chat.msg%></textarea>
      <br />
      <button>edit</button>
    </form>
  </body>
</html>
